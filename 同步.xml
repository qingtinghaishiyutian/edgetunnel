name: Sync edgetunnel beta2.0

on:
  schedule:
    - cron: '0 * * * *'  # 每小时同步一次
  workflow_dispatch:

jobs:
  sync:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v3
        with:
          ref: beta2.0

      - name: Configure Git
        run: |
          git config user.name "github-actions"
          git config user.email "github-actions@users.noreply.github.com"

      - name: Add upstream remote
        run: |
          git remote add upstream https://github.com/cmliu/edgetunnel.git || true
          git fetch upstream

      - name: Check for updates
        id: check_update
        run: |
          LOCAL=$(git rev-parse HEAD)
          REMOTE=$(git rev-parse upstream/beta2.0)
          echo "local=$LOCAL" >> $GITHUB_OUTPUT
          echo "remote=$REMOTE" >> $GITHUB_OUTPUT
          if [ "$LOCAL" = "$REMOTE" ]; then
            echo "No updates available."
            exit 0
          else
            echo "Updates detected."
          fi

      - name: Merge and push updates
        if: steps.check_update.outputs.local != steps.check_update.outputs.remote
        run: |
          git checkout beta2.0
          git merge upstream/beta2.0 --ff-only
          git push origin beta2.0

      - name: Sync complete
        if: steps.check_update.outputs.local != steps.check_update.outputs.remote
        run: echo "Successfully synchronized beta2.0 from upstream repository."
